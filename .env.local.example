# ============================================================
# FramePostReady — Environment Variables
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.
# ============================================================

# Anthropic Claude API
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Airtable
# PAT: https://airtable.com/create/tokens
# Base ID: Found in the API docs for your base (starts with "app")
AIRTABLE_PAT=patxxxxx
AIRTABLE_BASE_ID=appxxxxx

# Apify — Zillow Scraper
# https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxxxx

# Google Drive API — Service Account
# Create at: https://console.cloud.google.com/
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxxxx@xxxxx.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxx\n-----END PRIVATE KEY-----"
GOOGLE_DRIVE_ROOT_FOLDER_ID=xxxxx

# Make.com Webhook Security
# Generate a random string: openssl rand -hex 32
MAKE_WEBHOOK_SECRET=xxxxx

# Resend (Email)
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NOTIFICATION_EMAIL=colby@frameandformstudio.com
